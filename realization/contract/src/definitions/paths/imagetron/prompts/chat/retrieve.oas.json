{
  "get": {
    "summary": "Retrieve Prompt Subjects Chat History",
    "description": "Retrieve the save prompts subjects chat history",
    "operationId": "retrievePromptSubjectsChatHistory",
    "tags": ["Prompts"],
    "x-badges": [{ "label": "Badged Endpoint", "color": "blue" }],
    "x-tag-expanded": true,
    "responses": {
      "200": {
        "description": "Successfully retrieve the chat history.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["history"],
              "properties": {
                "history": {
                  "type": "array",
                  "description": "The `ObtainPromptSubjectsChatHistoryCollection` [items](/#/schemas/prompts-chatgpt-message-item) history arrays including the latest chat input and the response from ChatGPT.",
                  "items": {
                    "$ref": "#/components/schemas/prompts-chatgpt-message-item"
                  }
                }
              }
            }
          }
        }
      }
    },
    "security": [
      {
        "ImagetronAPIKeyAuth": []
      }
    ]
  },
  "components": {
    "$ref": "../../../../components/components.oas.json#/components"
  },
  "fields": {
    "$ref": "../../../../partials/fields.oas.json#/fields"
  }
}
